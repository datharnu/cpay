PORT=3001
DATABASE_URL=./cpay.sqlite
CORS_ORIGIN=http://localhost:3000
# Set false to block all *.vercel.app origins (not recommended for Vercel frontend)
CORS_ALLOW_VERCEL=true

# Render: CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
# Render: CORS_ALLOW_VERCEL=true allows any Vercel preview/production URL
# Render: WEBHOOK_URL=https://YOUR-SERVICE.onrender.com/webhooks/nomba
# Render: NOMBA_WEBHOOK_SECRET=from Nomba dashboard (optional in sandbox)
# Render: SKIP_WEBHOOK_SIGNATURE=true only if Nomba has not issued a signing key yet

SEED_SANDBOX_PARTNERS=false

NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=
# Hackathon TEST keys → https://sandbox.nomba.com
# Hackathon LIVE keys → https://api.nomba.com
NOMBA_BASE_URL=https://sandbox.nomba.com
WEBHOOK_URL=
