PORT=3001
# Local: SQLite file
DATABASE_URL=./cpay.sqlite
# Production (Render): use free Neon Postgres so data survives restarts
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
CORS_ORIGIN=http://localhost:3000
# Set false to block all *.vercel.app origins (not recommended for Vercel frontend)
CORS_ALLOW_VERCEL=true

# Render checklist:
# NOMBA_BASE_URL=https://api.nomba.com          (hackathon LIVE keys)
# WEBHOOK_URL=https://YOUR-SERVICE.onrender.com/webhooks/nomba
# NOMBA_WEBHOOK_SECRET=<from Nomba>             (required on Render — do not skip verification)
# Do NOT set SKIP_WEBHOOK_SIGNATURE on Render.

SEED_SANDBOX_PARTNERS=false

NOMBA_ACCOUNT_ID=
NOMBA_SUB_ACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=
# Hackathon TEST keys  → https://sandbox.nomba.com  (local dev, 2 VA limit)
# Hackathon LIVE keys  → https://api.nomba.com      (Render + judge demo)
NOMBA_BASE_URL=https://sandbox.nomba.com
WEBHOOK_URL=
